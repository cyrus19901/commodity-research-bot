# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Gordon — withgordon.ai → your agent → Connect
# The bot's Gordon agent authorises x402 payments to StableEnrich (primary) and Untitled Financial (optional)
GORDON_PLATFORM_URL=https://api.withgordon.ai
GORDON_AGENT_API_KEY=gak_pub_...
GORDON_AGENT_API_SECRET=gak_sec_...

# Pyth Hermes feed IDs — verify at https://pyth.network/price-feeds (filter: Metal)
PYTH_FEED_XAU=0x765d2ba906dbc32ca17cc11f5310a89e9ee1f6420508c63861f2f8ba4ee34bb2
PYTH_FEED_XAG=0xf2fb02c32b055c805e7238d628e5e9dadef274376114eb1f012337cabe93871e
PYTH_FEED_XPD=0x80367e9664197f37d89a07a804dffd2101c479c7c4e8490501bc9d9e1e7f9021
PYTH_FEED_XPT=0x398e4bbc7cbf89d6648c21e08019d878967677753b3096799595c78f805a34e5

# How often to poll Pyth for prices (seconds)
POLL_INTERVAL_SECONDS=60

# Minimum % move to trigger research (0.01 = 1%)
MOVE_THRESHOLD=0.01

# % move that also fires the cascade endpoint — $0.75 vs $0.40 base cost (0.02 = 2%)
CASCADE_THRESHOLD=0.02

# Optional Slack/Discord/custom webhook for alerts (leave blank = stdout only)
ALERT_WEBHOOK_URL=

# Research mode: 'agent' (Claude picks tools autonomously) or 'scripted' (fixed endpoint calls)
# Defaults to 'agent'
RESEARCH_MODE=agent
